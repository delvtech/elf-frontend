{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "outDir": "./build/",
    "resolveJsonModule": true,
    "paths": {
      "src": [
        "./src"
      ],
      "src/*": [
        "./src/*"
      ],
    },
  },
  "include": [
    "./src/**/*",
    "../schema/*",
    "./hardhat.config.ts"
  ],
  "exclude": [
    "../frontend/**/*"
  ],
  "files": [
    "./src/**/*",
    "./hardhat.config.ts"
  ]
}