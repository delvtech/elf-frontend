  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "name": "elf-frontend",
  "private": true,
  "scripts": {
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "add:language": "bash ./scripts/add-language.sh",
    "build": "next build",
    "build:goerli-app": "bash ./scripts/build.sh goerli",
    "build:mainnet-app": "bash ./scripts/build.sh mainnet",
    "build:coingecko-json": "bash ./scripts/build-coingecko-json.sh",
    "build:tailwind": "tailwindcss build src/styles/tailwind.css -o src/styles/tailwind.output.css",
    "build:tailwindcss-classnames": "tailwindcss-classnames --config tailwind.config.js -o src/efi-tailwindcss-classnames/index.ts",
    "build:version-json": "bash ./scripts/build-version-json.sh",
    "depcruise": "depcruise --config .dependency-cruiser.js src",
    "copy-testnet-jsons": "npm run copy-testnet-addresses && npm run copy-testnet-tokenlist",
    "copy-testnet-addresses": "sh ./scripts/copy-testnet-addresses.sh",
    "copy-testnet-tokenlist": "sh ./scripts/copy-testnet-tokenlist.sh",
    "lint": "tsc --noEmit && eslint src/**/*.ts{,x}",
    "lint:fix": "tsc --noEmit && eslint --fix src/**/*.ts{,x}",
    "postinstall": "npm run build:version-json",
    "prebuild": "npm run build:version-json && npm run build:tailwind",
    "prestart": "npm run build:version-json && npm run build:tailwind",
    "prettier": "prettier --write src/**/*.ts{,x}",
    "prettier:check": "prettier --check src/**/*.ts{,x}",
    "start": "next start",
    "start:goerli-app": "bash ./scripts/start.sh goerli",
    "start:mainnet-app": "bash ./scripts/start.sh mainnet",
    "start:testnet-app": "bash ./scripts/start.sh testnet",
    "dev": "next dev",
    "start:dev": "bash ./scripts/dev.sh",
    "start:dev-goerli-app": "npm run start:dev goerli",
    "start:dev-mainnet-app": "npm run start:dev mainnet",
    "start:dev-testnet-app": "npm run start:dev testnet",
    "test": "jest",
    "test:coverage": "npm run test -- --coverage --watchAll=false",
    "update-elf-contracts-typechain": "npm install git+https://github.com/element-fi/elf-contracts-typechain.git",
    "update-elf-tokenlist": "npm install git+https://github.com/element-fi/elf-tokenlist.git",
    "update:language": "bash ./scripts/update-language.sh",
    "vercel-build-check": "bash ./scripts/vercel-build-check.sh"
  },
  "version": "0.1.0"
}
