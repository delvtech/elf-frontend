# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# these are copied in from the top-level scripts and will be different on every
# machine
src/tokenlists/*
src/addresses/*
# This definition file is an exception as it does not change on every machine
# and CI will fail without it.
!src/addresses/AddressesJsonFile.d.ts
# This is a stub used for unit tests, it does not change on every machine
!src/addresses/mock.addresses.json

# misc
.DS_Store

# https://create-react-app.dev/docs/adding-custom-environment-variables/#adding-development-environment-variables-in-env
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# These are generated fresh on every build
version.output.json
tailwind.output.css

.eslintcache
