{
  "name": "efi-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@blueprintjs/core": "^3.35.0",
    "@blueprintjs/icons": "^3.22.0",
    "@blueprintjs/select": "^3.14.3",
    "@ethersproject/abi": "^5.0.7",
    "@ethersproject/bytes": "^5.0.5",
    "@ethersproject/contracts": "^5.0.5",
    "@ethersproject/hash": "^5.0.6",
    "@ethersproject/providers": "^5.0.14",
    "@ethersproject/units": "^5.0.6",
    "@reach/router": "^1.3.4",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "@types/classnames": "^2.2.10",
    "@types/d3-array": "^2.3.0",
    "@types/fuzzaldrin-plus": "^0.6.1",
    "@types/jest": "^24.0.0",
    "@types/node": "^14.14.5",
    "@types/reach__router": "^1.3.6",
    "@types/react": "^16.9.55",
    "@types/react-dom": "^16.9.9",
    "@types/warning": "^3.0.0",
    "@visx/axis": "^1.1.0",
    "@visx/brush": "^1.1.0",
    "@visx/curve": "^1.0.0",
    "@visx/gradient": "^1.0.0",
    "@visx/group": "^1.0.0",
    "@visx/mock-data": "^1.0.0",
    "@visx/pattern": "^1.1.0",
    "@visx/scale": "^1.1.0",
    "@visx/shape": "^1.1.0",
    "@walletconnect/web3-provider": "^1.3.1",
    "@web3-react/abstract-connector": "^6.0.7",
    "@web3-react/core": "^6.1.1",
    "@web3-react/injected-connector": "^6.0.7",
    "classnames": "^2.2.6",
    "d3-array": "^2.8.0",
    "ethers": "^5.0.19",
    "fontsource-poppins": "^3.0.9",
    "fuzzaldrin-plus": "^0.6.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-query": "^2.25.2",
    "react-query-devtools": "^2.6.0",
    "react-scripts": "4.0.0",
    "react-spring": "^8.0.27",
    "react-use": "^15.3.4",
    "tailwindcss": "^1.9.6",
    "tailwindcss-classnames": "^1.9.0",
    "ttag": "^1.7.22",
    "typescript": "~3.8.2",
    "warning": "^4.0.3",
    "web3": "^1.3.0"
  },
  "scripts": {
    "add:language": "bash ./scripts/add-language.sh",
    "build": "react-scripts build",
    "build:tailwind": "tailwindcss build src/tailwind.css -o src/tailwind.output.css",
    "build:version-json": "bash ./scripts/build-version-json.sh",
    "eject": "react-scripts eject",
    "lint": "tsc --noEmit && eslint src/**/*.ts{,x}",
    "lint:fix": "tsc --noEmit && eslint --fix src/**/*.ts{,x}",
    "depcruise": "depcruise --config .dependency-cruiser.js src",
    "prebuild": "npm run build:version-json && npm run build:tailwind",
    "prestart": "npm run build:version-json && npm run build:tailwind",
    "postinstall": "npm run build:version-json",
    "prettier": "prettier --write src/**/*.ts{,x}",
    "prettier:check": "prettier --check src/**/*.ts{,x}",
    "start": "react-scripts start",
    "test": "react-scripts test",
    "update:language": "bash ./scripts/update-language.sh"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@typechain/ethers-v5": "^2.0.0",
    "dependency-cruiser": "^9.15.1",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-jest": "^24.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "husky": "^4.3.0",
    "lint-staged": "^10.5.0",
    "prettier": "^2.1.2",
    "ttag-cli": "^1.8.6",
    "typechain": "^3.0.0"
  }
}
